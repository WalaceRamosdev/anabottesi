            to {
                transform: rotateY(-70deg);
            }
        }
    </style>

    <script>
        import { gsap } from "gsap";

        // Função para criar borboletas
        const createButterflies = (
            containerId: string,
            count: number,
            className = "manual-butterfly",
            opacity = 0.15,
        ) => {
            const container = document.getElementById(containerId);
            if (!container) return;

            // Se já tiver filhas, não recria
            if (container.children.length > 0) return;

            for (let i = 0; i < count; i++) {
                const butterfly = document.createElement("div");
                butterfly.className = className;
                butterfly.innerHTML = `
                <div class="butterfly-wing left"></div>
                <div class="butterfly-wing right"></div>
            `;

                const rect = container.getBoundingClientRect();
                const startX = Math.random() * rect.width;
                const startY = Math.random() * rect.height;

                gsap.set(butterfly, {
                    x: startX,
                    y: startY,
                    scale: 0.4 + Math.random() * 0.6,
                    rotation: Math.random() * 360,
                    opacity: opacity,
                });

                container.appendChild(butterfly);
                animateButterfly(butterfly, rect.width, rect.height, opacity);
            }
        };

        const animateButterfly = (
            el: HTMLElement | Element,
            maxX: number,
            maxY: number,
            baseOpacity: number,
        ) => {
            gsap.to(el, {
                x: Math.random() * maxX,
                y: Math.random() * maxY,
                rotation: `+=${Math.random() * 180 - 90}`,
                duration: 10 + Math.random() * 10,
                ease: "sine.inOut",
                onComplete: () => animateButterfly(el, maxX, maxY, baseOpacity),
            });

            gsap.to(el, {
                opacity: baseOpacity * 0.5,
                duration: 2 + Math.random() * 2,
                repeat: -1,
                yoyo: true,
            });
        };

        const init = () => {
            // Borboletas de fundo do manual
            createButterflies("manual-butterfly-container", 12);

            // Borboletas destacadas da seção IA
            createButterflies("ai-section-butterflies", 6, "ai-butterfly", 0.6);
        };

        // Função Global para Copiar e Notificar
        (window as any).copyAndNotify = () => {
            const pre = document.getElementById("ai-copy-text");
            if (!pre) return;

            navigator.clipboard.writeText(pre.innerText).then(() => {
                const toast = document.getElementById("copy-toast");
                if (!toast) return;

                // Reset e Animação de entrada
                toast.classList.remove("opacity-0", "translate-y-10");
                toast.classList.add("opacity-100", "translate-y-0");

                // Animação de saída
                setTimeout(() => {
                    toast.classList.add("opacity-0", "translate-y-10");
                    toast.classList.remove("opacity-100", "translate-y-0");
                }, 3000);
            });
        };

        // Inicializa quando o DOM estiver pronto
        if (
            document.readyState === "complete" ||
            document.readyState === "interactive"
        ) {
            init();
        } else {
            document.addEventListener("DOMContentLoaded", init);
        }

        // Suporte para navegação do Astro
        document.addEventListener("astro:after-swap", init);
    </script>
</Layout>
