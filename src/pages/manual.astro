            z-index: 1;
        }

        :global(.ai-butterfly .butterfly-wing) {
            background-color: rgba(255, 255, 255, 0.8) !important;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
        }

        @keyframes flap-left {
            from {
                transform: rotateY(0deg);
            }
            to {
                transform: rotateY(70deg);
            }
        }

        @keyframes flap-right {
