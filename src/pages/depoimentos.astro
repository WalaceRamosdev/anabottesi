---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const testimonials = [
    {
        name: "N. T.",
        role: "Paciente Acompanhada",
        text: "Acolhimento é a palavra que define o trabalho da Ana!! Uma pessoa incrível, o trabalho que ela realiza é surreal. A Ana é uma pessoa muito querida, a escuta que ela tem é lindo de viver <3 Não troco e super indico o trabalho dela!",
        stars: 5,
        source: "Google Review",
        tags: ["Acolhimento", "Escuta", "Indicação"]
    },
    {
        name: "C. C.",
        role: "Paciente Acompanhada",
        text: "Ana é incrível!!! O acolhimento dela comigo e atenção são incríveis desde o primeiro contato. Eu super indico, excelente profissional!",
        stars: 5,
        source: "Google Review",
        tags: ["Atenção", "Profissionalismo", "Acolhimento"]
    },
    {
        name: "R. P. S.",
        role: "Paciente Acompanhada",
        text: "A Ana é maravilhosa, super recomendo!",
        stars: 5,
        source: "Google Review",
        tags: ["Recomendado", "Excelência"]
    },
    {
        name: "L. N.",
        role: "Paciente Acompanhada",
        text: "Ana é uma excelente analista, com escuta ativa, acolhimento e intervenção no momento exato. Atendimento humano de verdade. Sinto que em 1 ano e 4 meses que estou com ela evoluí muito nos meus processos e em autoconhecimento. Gratidão até aqui.",
        stars: 5,
        source: "Google Review",
        tags: ["Evolução", "Autoconhecimento"]
    },
    {
        name: "L. S.",
        role: "Paciente Acompanhada",
        text: "Poderia começar dizendo tantas coisas, mas o resumo é simples: o trabalho da Ana salvou a minha vida. Hoje sou uma mulher feliz, com autonomia, e nunca estive tão bem. A Ana é gentil, profissional, agradável e, acima de tudo, humana. Não troco o trabalho dela por absolutamente nada.",
        stars: 5,
        source: "Google Review",
        tags: ["Autonomia", "Transformação"]
    },
    {
        name: "G. R.",
        role: "Google Review",
        text: "A Ana é uma profissional extremamente ética e atenciosa. Desde o início me fez sentir acolhida e respeitada. O atendimento é conduzido com muita sensibilidade e profundidade. Super recomendo!",
        stars: 5,
        source: "Google Review",
        tags: ["Ética", "Respeito"]
    }
];

const title = "Prova Real | Depoimentos e Transformações - Ana Bottesi";
const description = "Veja os depoimentos de mulheres que transformaram suas vidas através da psicanálise com Ana Bottesi. Um espaço de acolhimento, cura e evolução.";
---

<Layout title={title} description={description}>
    <Header />
    
    <main class="overflow-hidden bg-[#F5F0EB]">
        <!-- Player de Áudio Relaxante -->
        <div class="fixed bottom-8 left-8 z-50 group flex flex-row-reverse items-center gap-4">
            <div class="bg-white/80 backdrop-blur-md px-4 py-2 rounded-full border border-brand-primary/10 shadow-xl opacity-0 group-hover:opacity-100 transition-all duration-500 -translate-x-4 group-hover:translate-x-0 pointer-events-none">
                <span class="text-xs font-bold uppercase tracking-widest text-brand-primary">Música de Fundo</span>
            </div>
            <button 
                id="audio-toggle"
                class="w-14 h-14 bg-brand-primary text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 relative overflow-hidden"
            >
                <div id="audio-wave" class="absolute inset-0 flex items-center justify-center gap-1 opacity-0 transition-opacity duration-300">
                    <span class="w-1 h-4 bg-white/40 rounded-full animate-[wave_1s_ease-in-out_infinite]"></span>
                    <span class="w-1 h-6 bg-white/60 rounded-full animate-[wave_1s_ease-in-out_0.2s_infinite]"></span>
                    <span class="w-1 h-4 bg-white/40 rounded-full animate-[wave_1s_ease-in-out_0.4s_infinite]"></span>
                </div>
                <i id="audio-icon" class="fa-solid fa-music text-xl"></i>
            </button>
            <audio id="bg-music" loop preload="auto">
                <source src="/audios/trilha-acolhedora.mp3" type="audio/mpeg">
            </audio>
        </div>

        <!-- Container de Borboletas Global da Página -->
        <div id="global-page-butterflies" class="fixed inset-0 pointer-events-none z-0"></div>

        <!-- Hero Section -->
        <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 text-center">
                <span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold uppercase tracking-[0.2em] text-brand-primary bg-brand-primary/5 rounded-full">
                    Prova Real
                </span>
                <h1 class="text-6xl md:text-9xl font-handwriting text-brand-primary mb-8" id="title-hero">
                    Vozes da Transformação
                </h1>
                
                <!-- Divisor Floral Premium -->
                <div class="flex justify-center -mt-6 opacity-90 mb-12">
                    <svg width="280" height="60" viewBox="0 0 280 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-brand-primary">
                        <path d="M10 53C50 53 80 33 140 60C200 33 230 53 270 53" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
                        <circle cx="140" cy="52" r="4" fill="currentColor" />
                    </svg>
                </div>

                <p class="max-w-2xl mx-auto text-xl md:text-2xl text-brand-text/70 italic font-serif leading-relaxed mb-12 uppercase tracking-wide">
                    A psicanálise é um convite para reescrever sua história. Aqui estão alguns relatos de mulheres que encontraram seu caminho através da escuta e do acolhimento.
                </p>
            </div>
        </section>

        <!-- Seção de Depoimentos Lado a Lado -->
        <section class="py-20 relative z-10">
            <div class="max-w-6xl mx-auto px-4 md:px-8">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
                    {testimonials.map((t, i) => (
                        <div class="testimonial-card relative bg-white p-10 md:p-12 rounded-[40px] shadow-2xl border border-brand-primary/5 hover:-translate-y-2 transition-all duration-500 group">
                            <!-- Aspas Gigantes Decorativas -->
                            <div class="absolute -top-4 -left-2 text-8xl font-serif text-brand-primary/5 select-none pointer-events-none group-hover:text-brand-primary/10 transition-colors duration-500">“</div>
                            
                            <div class="relative z-10 min-h-[250px] flex flex-col justify-between">
                                <div class="mb-8">
                                    <div class="flex gap-1 text-yellow-500 text-[10px] mb-6">
                                        {[...Array(t.stars)].map(() => <i class="fa-solid fa-star"></i>)}
                                    </div>
                                    
                                    <p class="text-brand-text/90 text-lg md:text-xl leading-relaxed italic font-medium">
                                        "{t.text}"
                                    </p>
                                </div>
                                
                                <footer class="border-t border-brand-primary/10 pt-6 mt-auto">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <cite class="not-italic block font-serif text-brand-primary font-bold text-xl">{t.name}</cite>
                                            <span class="text-[10px] uppercase tracking-[0.2em] text-brand-text/40">{t.role}</span>
                                        </div>
                                        <div class="w-10 h-10 bg-brand-primary/5 rounded-full flex items-center justify-center text-brand-primary/30">
                                            <i class="fa-solid fa-quote-right"></i>
                                        </div>
                                    </div>
                                </footer>
                            </div>

                            <!-- Borboleta flutuante interna -->
                            <div class="absolute -bottom-6 -right-6 w-24 h-24 opacity-0 group-hover:opacity-20 transition-all duration-700 -rotate-12 translate-x-4">
                                <svg version="1.1" viewBox="0 0 100 100" class="w-full h-full fill-brand-primary">
                                    <path d="M50,85 C50,85 35,65 35,45 C35,25 50,15 50,15 C50,15 65,25 65,45 C65,65 50,85 50,85 Z" />
                                    <path d="M50,85 C50,85 25,75 15,55 C5,35 25,20 25,20 C25,20 35,30 40,50 C45,70 50,85 50,85 Z" />
                                    <path d="M50,85 C50,85 75,75 85,55 C95,35 75,20 75,20 C75,20 65,30 60,50 C55,70 50,85 50,85 Z" />
                                </svg>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- CTA Final -->
        <section class="py-32 relative z-10 overflow-hidden">
            <div class="max-w-4xl mx-auto px-4 md:px-8 text-center bg-white/50 backdrop-blur-md p-16 rounded-[48px] border border-white shadow-xl">
                <h2 class="text-4xl md:text-5xl font-serif italic text-brand-primary mb-8">
                    "Todo fim é um começo oculto."
                </h2>
                <p class="text-xl text-brand-text/60 mb-12">
                    Inicie sua jornada de autoconhecimento hoje mesmo.
                </p>
                <a
                    href="https://wa.me/5511973454557?text=Olá Ana! Vi a página de depoimentos e me identifiquei muito. Gostaria de saber mais sobre o atendimento."
                    target="_blank"
                    class="btn-primary inline-block px-12 py-5 text-xl font-bold shadow-2xl hover:scale-105 transition-all duration-300"
                >
                    Agendar um acolhimento
                </a>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    @keyframes wave {
        0%, 100% { transform: scaleY(1); }
        50% { transform: scaleY(0.4); }
    }

    /* Butterfly Styles (Optimized) */
    :global(.page-butterfly) {
        position: absolute;
        width: 30px;
        height: 25px;
        pointer-events: none;
        z-index: 5;
    }

    :global(.butterfly-wing) {
        position: absolute;
        width: 50%;
        height: 100%;
        background-color: #8c7355; /* brand-primary */
        opacity: 0.15;
        border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
    }

    :global(.butterfly-wing.left) {
        left: 0;
        transform-origin: right center;
        animation: flap-left 0.5s ease-in-out infinite alternate;
    }

    :global(.butterfly-wing.right) {
        right: 0;
        transform-origin: left center;
        animation: flap-right 0.5s ease-in-out infinite alternate;
    }

    @keyframes flap-left {
        from { transform: rotateY(0deg); }
        to { transform: rotateY(70deg); }
    }

    @keyframes flap-right {
        from { transform: rotateY(0deg); }
        to { transform: rotateY(-70deg); }
    }
</style>

<script>
    import { gsap } from "gsap";

    const initAudio = () => {
        const audio = document.getElementById("bg-music") as any;
        const btn = document.getElementById("audio-toggle");
        const icon = document.getElementById("audio-icon");
        const wave = document.getElementById("audio-wave");
        
        if (!audio || !btn || !icon || !wave) return;

        // Definir volume 30% mais baixo para ser ambiente
        audio.volume = 0.3;

        btn.onclick = () => {
            if (audio.paused) {
                // Feedback imediato
                icon.style.display = "none";
                wave.style.opacity = "1";
                audio.play();
            } else {
                audio.pause();
                icon.style.display = "block";
                wave.style.opacity = "0";
            }
        };

        // Autoplay attempt
        audio.play().then(() => {
            icon.style.display = "none";
            wave.style.opacity = "1";
        }).catch(() => {});
    };

    const initButterflies = () => {
        const container = document.getElementById("global-page-butterflies");
        if (!container || container.children.length > 0) return;

        const count = 15;
        for (let i = 0; i < count; i++) {
            const b = document.createElement("div");
            b.className = "page-butterfly";
            b.innerHTML = '<div class="butterfly-wing left"></div><div class="butterfly-wing right"></div>';
            
            gsap.set(b, {
                x: Math.random() * window.innerWidth,
                y: Math.random() * window.innerHeight,
                scale: 0.5 + Math.random() * 1,
                rotation: Math.random() * 360,
                opacity: 0
            });

            container.appendChild(b);

            gsap.to(b, { opacity: 1, duration: 2 });
            
            const animateButterfly = (el: HTMLElement) => {
                gsap.to(el, {
                    x: `+=${Math.random() * 400 - 200}`,
                    y: `+=${Math.random() * 400 - 200}`,
                    rotation: `+=${Math.random() * 90 - 45}`,
                    duration: 10 + Math.random() * 15,
                    ease: "sine.inOut",
                    onComplete: () => animateButterfly(el)
                });
            };
            animateButterfly(b);
        }
    };

    const initAll = () => {
        initAudio();
        initButterflies();
    };

    if (document.readyState === "complete") {
        initAll();
    } else {
        window.addEventListener("load", initAll);
    }
    document.addEventListener("astro:after-swap", initAll);
</script>


